FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y \
  git \
  xdg-utils \
  python3 \
  python3-pip \
  wget \
  poppler-utils \
  libmagic1 \
  tesseract-ocr \
  tesseract-ocr-por \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g opencode-ai@1.17.20 @ai-sdk/openai-compatible

COPY infra/scripts/requirements.txt /tmp/requirements.txt
RUN pip3 install -r /tmp/requirements.txt --break-system-packages && rm -f /tmp/requirements.txt

COPY scripts/consultar-supabase.py /home/node/.local/bin/consultar-supabase
COPY scripts/file-reader.py /home/node/.local/bin/file-reader
RUN chmod +x /home/node/.local/bin/consultar-supabase /home/node/.local/bin/file-reader

RUN mkdir -p \
  /home/node/.config/opencode \
  /home/node/.local/share/opencode \
  /home/node/user-data \
  /workspace \
  /home/node/.agents \
  && chown -R node:node /home/node/.config /home/node/.local /home/node/user-data /workspace /home/node/.agents

ENV OPENCODE_HOSTNAME=0.0.0.0
ENV OPENCODE_PORT=4096
ENV NODE_PATH=/usr/local/lib/node_modules

COPY --chown=node:node infra/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER node
WORKDIR /workspace

EXPOSE 4096

ENTRYPOINT ["/entrypoint.sh"]
CMD ["opencode", "web", "--hostname", "0.0.0.0", "--port", "4096", "--print-logs"]
