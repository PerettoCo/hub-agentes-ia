{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/deepseek-v4-flash-free",
  "small_model": "litellm/deepseek-v4-flash-free",
  "enabled_providers": ["litellm"],
  "provider": {
    "litellm": {
      "name": "V4 LiteLLM",
      "type": "openai-compatible",
      "apiKey": "{env:OPENAI_API_KEY}",
      "baseURL": "{env:OPENAI_BASE_URL}"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}
