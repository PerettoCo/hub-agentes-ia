{
  "model": "litellm/sofia-daily",
  "small_model": "opencode/deepseek-v4-flash-free",
  "enabled_providers": [
    "litellm",
    "opencode"
  ],
  "disabled_providers": [
    "openai",
    "anthropic",
    "gemini",
    "google",
    "openrouter",
    "amazon-bedrock",
    "azure",
    "groq",
    "fireworks",
    "together",
    "mistral",
    "deepseek",
    "perplexity",
    "replicate",
    "cohere",
    "huggingface",
    "github-copilot",
    "gitlab",
    "vertex",
    "cloudflare",
    "cerebras",
    "baseten",
    "deepinfra",
    "moonshot",
    "minimax",
    "nvidia",
    "ollama",
    "lmstudio"
  ],
  "provider": {
    "litellm": {
      "name": "Sofia AI (LiteLLM)",
      "type": "openai-compatible",
      "apiKey": "{env:LITELLM_VIRTUAL_KEY}",
      "baseURL": "https://litellm.fvmarketing.com.br/v1",
      "models": {
        "sofia-daily": {
          "name": "Sofia AI Daily"
        },
        "claude-sonnet-4": {
          "name": "Sofia AI Complex"
        }
      }
    }
  },
  "experimental": {
    "policies": [
      {
        "effect": "deny",
        "action": "provider.use",
        "resource": "*"
      },
      {
        "effect": "allow",
        "action": "provider.use",
        "resource": "litellm"
      },
      {
        "effect": "allow",
        "action": "provider.use",
        "resource": "opencode"
      }
    ]
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}