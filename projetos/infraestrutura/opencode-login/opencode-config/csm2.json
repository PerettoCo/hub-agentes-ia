{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/sofia-daily",
  "small_model": "litellm/deepseek-v4-flash-free",
  "enabled_providers": [
    "litellm"
  ],
  "provider": {
    "litellm": {
      "name": "Sofia AI",
      "type": "openai-compatible",
      "apiKey": "{env:LITELLM_VIRTUAL_KEY}",
      "baseURL": "https://litellm.fvmarketing.com.br/v1",
      "models": {
        "sofia-daily": {
          "name": "Sofia AI Daily"
        },
        "claude-sonnet-4": {
          "name": "Sofia AI Complex"
        },
        "deepseek-v4-flash-free": {
          "name": "Sofia AI Basic"
        }
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}