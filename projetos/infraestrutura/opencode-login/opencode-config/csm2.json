{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/deepseek-v4-flash-free",
  "small_model": "litellm/deepseek-v4-flash-free",
  "enabled_providers": ["litellm", "opencode", "openrouter"],
  "provider": {
    "litellm": {
      "name": "Sofia AI (LiteLLM)",
      "npm": "@ai-sdk/openai-compatible",
      "apiKey": "{env:LITELLM_VIRTUAL_KEY}",
      "options": {
        "baseURL": "http://litellm:4000/v1"
      },
      "models": {
        "deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free"
        }
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}
