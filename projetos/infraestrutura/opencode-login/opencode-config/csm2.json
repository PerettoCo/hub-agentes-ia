{
  "modelProvider": "litellm",
  "model": "litellm/deepseek-v4-flash-free",
  "small_model": "litellm/deepseek-v4-flash-free",
  "customProviders": {
    "litellm": {
      "name": "Sofia AI (LiteLLM)",
      "type": "openai-compatible",
      "apiKey": "{env:LITELLM_VIRTUAL_KEY}",
      "baseURL": "http://litellm:4000/v1"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}
