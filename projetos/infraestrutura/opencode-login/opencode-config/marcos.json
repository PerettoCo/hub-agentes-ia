{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/deepseek-v4-flash-free",
  "enabled_providers": ["litellm"],
  "provider": {
    "litellm": {
      "type": "openai-compatible",
      "apiKey": "{env:LITELLM_VIRTUAL_KEY}",
      "baseURL": "https://litellm.fvmarketing.com.br/v1"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}
