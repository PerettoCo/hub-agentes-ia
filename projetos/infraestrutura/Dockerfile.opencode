FROM node:20-bookworm-slim

# === Python + dependencias para leitura de arquivos e RAG ===
RUN apt-get update && apt-get install -y \
    git xdg-utils \
    python3 python3-pip python3-venv \
    tesseract-ocr tesseract-ocr-por \
    poppler-utils \
    libmagic1 \
    antiword catdoc \
    && rm -rf /var/lib/apt/lists/*

# Atualiza pip e instala dependencias Python globais
RUN python3 -m venv /opt/venv && \
    . /opt/venv/bin/activate && \
    pip install --upgrade pip && \
    pip install \
        pypdf>=4.0.0 \
        python-docx>=1.0.0 \
        python-pptx>=0.6.0 \
        openpyxl>=3.1.0 \
        python-magic>=0.4.0 \
        olefile>=0.47 \
        odfpy>=1.4.0 \
        striprtf>=0.0.22 \
        pytesseract>=0.3.0 \
        pillow>=10.0.0 \
        httpx>=0.27.0 \
        python-dotenv>=1.0.0 \
        tqdm>=4.66.0 \
        typer>=0.12.0

ENV PATH="/opt/venv/bin:$PATH"

# === OpenCode ===
RUN npm install -g opencode-ai@latest @ai-sdk/openai-compatible

RUN mkdir -p /home/node/.config/opencode /home/node/.local/share/opencode /workspace && \
    chown -R node:node /home/node/.config /home/node/.local /workspace

ENV OPENCODE_HOSTNAME=0.0.0.0
ENV OPENCODE_PORT=4096
ENV NODE_PATH=/usr/local/lib/node_modules

COPY --chown=node:node opencode-login/scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER node
WORKDIR /workspace

EXPOSE 4096

ENTRYPOINT ["/entrypoint.sh"]
CMD ["opencode", "web", "--hostname", "0.0.0.0", "--port", "4096", "--print-logs", "--log-level=DEBUG"]
