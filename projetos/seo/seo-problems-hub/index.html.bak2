<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta não?me="viewport" content="width=device-width, initial-scale=1.0">
<title>SEO Problems Hub — Knowledge Base · V4 Company</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --font-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', ui-monospace, monospace;
  --accent: #e50914;
  --accent-hover: #ff222d;
  --accent-dark: #d4070f;
  --accent-subtle: rgba(229, 9, 20, 0.07);
  --accent-gradient: linear-gradient(135deg, #e50914 0%, #ff222d 100%);
  --sidebar-bg: #0a0a0f;
  --sidebar-border: #1a1a26;
  --sidebar-text: #9494a8;
  --sidebar-heading: #e4e4ec;
  --sidebar-hover: #1a1a22;
  --content-bg: #ffffff;
  --content-text: #1a1a2e;
  --content-muted: #6a6a84;
  --content-border: #e2e2ec;
  --card-bg: #f8f8fc;
  --card-hover: #f0f0f8;
  --card-border: #e2e2ec;
  --gold: #c9a96e;
  --tag-bg: rgba(229, 9, 20, 0.06);
  --tag-border: rgba(229, 9, 20, 0.15);
  --code-bg: #f5f5f7;
  --table-border: #e2e2ec;
  --sidebar-width: 280px;
  --header-height: 64px;
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 16px;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
  --green: #1a8a3f;
  --amber: #c97d0e;
  --blue: #1a4a8c;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-sans); font-size: 15.5px; line-height: 1.75;
  color: var(--content-text); background: var(--content-bg); display: flex;
  min-height: 100vh; -webkit-font-smoothing: antialiased;
}
.header {
  position: fixed; top: 0; left: var(--sidebar-width); right: 0;
  height: var(--header-height);
  background: var(--sidebar-bg); border-bottom: 1px solid var(--sidebar-border);
  display: flex; align-items: center; padding: 0 36px; z-index: 100; gap: 12px;
}
.header h1 { font-size: 14px; font-weight: 700; color: var(--sidebar-heading); }
.header .subtitle { font-size: 12px; color: var(--sidebar-text); }
.header-badge {
  margin-left: auto; font-size: 10px; font-weight: 600; color: #fff;
  background: var(--accent); padding: 3px 10px; border-radius: 20px;
  text-transform: uppercase; letter-spacing: 0.3px;
}
.sidebar {
  position: fixed; top: 0; left: 0; bottom: 0; width: var(--sidebar-width);
  background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border);
  overflow-y: auto; z-index: 200;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: #2a2a3e; border-radius: 4px; }
.sidebar-logo {
  padding: 20px 20px 16px; border-bottom: 1px solid var(--sidebar-border);
  display: flex; flex-direction: column; align-items: center; text-align: center;
}
.sidebar-logo .logo-img { width: 120px; height: auto; object-fit: contain; margin-bottom: 6px; }
.sidebar-logo .version {
  font-size: 9.5px; color: var(--sidebar-text); font-weight: 500;
  text-transform: uppercase; letter-spacing: 0.5px;
}
.sidebar não?v ul { list-style: none; padding: 0; margin: 0; }
.sidebar não?v ul li { margin: 0; }
.sidebar .não?v-link {
  display: block; padding: 7px 20px; font-size: 12.5px; font-weight: 500;
  color: var(--sidebar-text); text-decoration: none;
  transition: all 0.2s ease; border-left: 3px solid transparent;
  line-height: 1.3; cursor: pointer;
}
.sidebar .não?v-link:hover { background: var(--sidebar-hover); color: var(--sidebar-heading); border-left-color: var(--accent); padding-left: 22px; }
.sidebar .não?v-link.level-0 {
  font-weight: 600; font-size: 11px; padding: 9px 20px 5px;
  color: var(--accent); text-transform: uppercase; letter-spacing: 0.4px;
  cursor: default;
}
.sidebar .não?v-link.level-0:hover { background: none; padding-left: 20px; }
.sidebar .não?v-link.não?v-sub { padding-left: 32px; font-size: 11.5px; }
.main {
  margin-left: var(--sidebar-width); margin-top: var(--header-height);
  flex: 1; min-width: 0;
}
.main > section {
  padding: 20px 48px 0 40px;
  margin-bottom: 28px;
  scroll-margin-top: calc(var(--header-height) + 16px);
}
.main h1.section-title {
  font-size: 22px; font-weight: 700; color: var(--accent);
  margin-bottom: 16px; padding-bottom: 10px;
  border-bottom: 3px solid var(--accent); letter-spacing: -0.4px;
  display: flex; align-items: center; gap: 10px;
}
.main h1.section-title::before {
  content: ''; display: inline-block; width: 4px; height: 24px;
  background: var(--accent-gradient); border-radius: 2px; flex-shrink: 0;
}
.main h2 { font-size: 17px; font-weight: 600; margin-top: 24px; margin-bottom: 8px; color: var(--content-text); }
.main h3 { font-size: 15px; font-weight: 600; margin-top: 20px; margin-bottom: 6px; }
.main h4 { font-size: 14px; font-weight: 600; margin-top: 16px; margin-bottom: 4px; color: var(--accent); }
.main p { margin-bottom: 10px; color: var(--content-text); }
.main strong { font-weight: 700; }
.main code {
  font-family: var(--font-mono); font-size: 12.5px; background: var(--code-bg);
  padding: 2px 7px; border-radius: 4px; color: var(--accent); border: 1px solid var(--content-border);
}
.main pre {
  background: #0d1117; color: #e6edf3; padding: 18px 22px; border-radius: var(--radius-md);
  overflow-x: auto; margin: 14px 0; font-size: 12.5px; line-height: 1.6; border: 1px solid #21262d;
}
.main pre code { background: none; color: inherit; padding: 0; border: none; font-size: 12.5px; }
.main ul, .main ol { margin: 6px 0 12px 22px; }
.main li { margin-bottom: 4px; line-height: 1.6; }
.main li::marker { color: var(--accent); }
.main table {
  width: 100%; border-collapse: separate; border-spacing: 0; margin: 14px 0;
  font-size: 12.5px; border-radius: var(--radius-sm); overflow: hidden;
  border: 1px solid var(--table-border);
}
.main th {
  background: var(--accent); font-weight: 600; text-align: left;
  padding: 9px 12px; font-size: 10.5px; text-transform: uppercase;
  letter-spacing: 0.5px; color: #fff;
  border-bottom: 1px solid var(--accent-dark);
}
.main th:not(:last-child) { border-right: 1px solid rgba(255,255,255,0.12); }
.main td {
  padding: 7px 11px; border-bottom: 1px solid var(--table-border);
  vertical-align: top; background: var(--content-bg);
}
.main tr:last-child td { border-bottom: none; }
.main tr:nth-child(even) td { background: var(--card-bg); }
.main tr:hover td { background: var(--accent-subtle); }
.main blockquote {
  border-left: 4px solid var(--accent); padding: 12px 16px; margin: 14px 0;
  background: var(--accent-subtle); border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 13.5px;
}
.main a { color: var(--accent); text-decoration: none; font-weight: 500; border-bottom: 1.5px solid transparent; }
.main a:hover { border-bottom-color: var(--accent); color: var(--accent-dark); }
.callout { padding: 10px 14px; border-radius: 8px; margin: 10px 0; font-size: 12.5px; border-left: 3px solid; }
.callout-info { background: var(--accent-subtle); border-color: var(--accent); }
.callout-warn { background: rgba(201, 109, 14, 0.06); border-color: var(--amber); }
.callout-good { background: rgba(26, 138, 63, 0.06); border-color: var(--green); }
.callout-tip { background: rgba(26, 74, 140, 0.06); border-color: var(--blue); }
.problem-card {
  background: var(--card-bg); border: 1px solid var(--card-border);
  border-radius: var(--radius-md); padding: 20px 24px; margin-bottom: 16px;
  transition: all 0.25s ease;
}
.problem-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.08); }
.problem-card h3 { margin: 0 0 8px; font-size: 15px; color: var(--accent); }
.problem-card .meta { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
.problem-card .meta-tag {
  font-size: 10px; padding: 2px 8px; border-radius: 4px;
  font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px;
}
.tag-critical { background: rgba(229,9,20,0.1); color: var(--accent); border: 1px solid rgba(229,9,20,0.2); }
.tag-high { background: rgba(201,109,14,0.1); color: var(--amber); border: 1px solid rgba(201,109,14,0.2); }
.tag-medium { background: rgba(26,74,140,0.1); color: var(--blue); border: 1px solid rgba(26,74,140,0.2); }
.tag-low { background: rgba(106,106,132,0.1); color: var(--content-muted); border: 1px solid rgba(106,106,132,0.2); }
.faq-item {
  border: 1px solid var(--content-border); border-radius: var(--radius-sm);
  margin: 6px 0; overflow: hidden;
}
.faq-q {
  padding: 10px 14px; background: var(--card-bg); font-weight: 600;
  font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 8px;
  transition: background 0.2s;
}
.faq-q:hover { background: var(--card-hover); }
.faq-q::before { content: '▸'; color: var(--accent); font-size: 14px; transition: transform 0.2s; }
.faq-q.open::before { transform: rotate(90deg); }
.faq-a {
  display: none; padding: 10px 14px 14px; font-size: 13px;
  border-top: 1px solid var(--content-border); line-height: 1.6;
}
.faq-a.open { display: block; }
.faq-a code { font-size: 12px; }
.divider { width: 60px; height: 3px; background: var(--accent-gradient); border-radius: 2px; margin: 6px 0 16px; }
.pop-list { counter-reset: pop-step; list-style: none; padding: 0; margin: 10px 0; }
.pop-list li {
  counter-increment: pop-step; padding: 8px 0 8px 36px; position: relative;
  font-size: 13px; border-bottom: 1px solid var(--content-border);
}
.pop-list li::before {
  content: counter(pop-step); position: absolute; left: 0; top: 7px;
  width: 24px; height: 24px; background: var(--accent); color: #fff;
  font-size: 10px; font-weight: 700; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.pop-list li:last-child { border: none; }
.tools-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px; margin: 10px 0;
}
.tool-card {
  background: var(--card-bg); border: 1px solid var(--card-border);
  border-radius: var(--radius-sm); padding: 10px 12px; font-size: 12px;
}
.tool-card .tool-não?me { font-weight: 600; color: var(--accent); font-size: 12px; }
.tool-card .tool-desc { color: var(--content-muted); font-size: 11px; margin-top: 2px; }
.cover-section {
  background: linear-gradient(135deg, #0d0d0d 0%, #1a1a1a 50%, #2a2a2a 100%);
  color: #fff; padding: 40px 48px 36px; position: relative; overflow: hidden;
  margin: 0;
}
.cover-section::before {
  content: ''; position: absolute; top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(circle, rgba(201,169,110,0.04) 0%, transparent 60%);
  pointer-events: none;
}
.cover-section .cover-content { position: relative; z-index: 1; max-width: 900px; }
.cover-section .cover-content::before {
  content: ''; position: absolute; top: -12px; left: 0;
  width: 120px; height: 1px;
  background: linear-gradient(90deg, var(--gold), transparent);
}
.cover-section .label {
  font-size: 11px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 1px; color: var(--gold); margin-bottom: 8px;
}
.cover-section h1 {
  font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800;
  line-height: 1.15; margin-bottom: 10px;
}
.cover-section p { color: rgba(255,255,255,0.7); font-size: 14px; max-width: 700px; }
.cover-section .gold-line {
  width: 60px; height: 2px; background: var(--gold); margin-top: 16px; border-radius: 1px;
}
@media (max-width: 768px) {
  .sidebar { display: none; }
  .header { left: 0; }
  .main { margin-left: 0; padding: 20px 16px 60px; }
  .main section { padding: 20px; }
  .cover-section { padding: 24px 20px; }
  .tools-grid { grid-template-columns: 1fr; }
}
</style>
</head>
